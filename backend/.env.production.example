APP_NAME=TradeReveal
APP_ENV=production
APP_KEY=base64:GENERA_QUESTA_CHIAVE_CON_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://api.tuodominio.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=sqlXXX.aruba.it
DB_PORT=3306
DB_DATABASE=nome_db
DB_USERNAME=utente_db
DB_PASSWORD=password_db

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.tuodominio.it

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.tuodominio.it
MAIL_PORT=587
MAIL_USERNAME=tuo_utente
MAIL_PASSWORD=tua_password
MAIL_FROM_ADDRESS="noreply@tuodominio.it"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
